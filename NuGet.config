<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!--
    NuGet source configuration for nuget-reporting-app

    ACTIVE SOURCE
    nuget.org is the only active source. This allows `dotnet build` and
    `dotnet pack` to work without any Artifactory credentials.

    JFROG ARTIFACTORY (COMMENTED OUT)
    The "jfrog-nuget" virtual repository on
    https://domain.jfrog.io proxies nuget.org plus any private feeds.

    To switch to Artifactory:
      1. Uncomment the <add> blocks in <packageSources> and
         <packageSourceCredentials> below.
      2. Set the JFROG_USER and JFROG_TOKEN environment variables, OR
         replace the %JFROG_USER% / %JFROG_TOKEN%
      3. Comment out (or remove) the nuget.org entry so all traffic is
         routed through the proxy.
  -->

  <packageSources>

    <!-- Public nuget.org (active) -->
    <clear />
    <add key="nuget.org"
         value="https://api.nuget.org/v3/index.json"
         protocolVersion="3" />

    <!-- JFrog Artifactory jfrog-nuget (disabled) 
    <add key="jfrog-nuget"
         value="https://domain.jfrog.io/artifactory/api/nuget/v3/jfrog-nuget/index.json"
         protocolVersion="3" />
    -->

  </packageSources>

  <packageSourceMapping>
    <!-- Route all packages through nuget.org while the JFrog source is off. -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>

    <!-- Uncomment when jfrog-nuget is active (and comment the nuget.org mapping above).
    <packageSource key="jfrog-nuget">
      <package pattern="*" />
    </packageSource>
    -->
  </packageSourceMapping>

  <packageSourceCredentials>
    <!--
    <jfrog-nuget>
      <add key="Username" value="%JFROG_USER%" />
      <add key="ClearTextPassword" value="%JFROG_TOKEN%" />
    </jfrog-nuget>
    -->
  </packageSourceCredentials>

</configuration>
